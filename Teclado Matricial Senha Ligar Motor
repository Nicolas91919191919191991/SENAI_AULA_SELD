#include <Keypad.h>

// ==========================
// Configuração do teclado
// ==========================
const byte LINHAS = 4;
const byte COLUNAS = 4;

char teclas[LINHAS][COLUNAS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte pinosLinhas[LINHAS] = {9, 8, 7, 6};
byte pinosColunas[COLUNAS] = {5, 4, 3, 2};

Keypad teclado = Keypad(makeKeymap(teclas),
                         pinosLinhas,
                         pinosColunas,
                         LINHAS,
                         COLUNAS);

// ==========================
// Configuração dos pinos
// ==========================
const int ledPin = 13;
const int botaoPin = 10;

// ==========================
// Senha do sistema
// ==========================
String senhaCorreta = "1234";
String senhaDigitada = "";

bool sistemaLiberado = false;

void setup() {
  pinMode(ledPin, OUTPUT);

  // Pull-up interno ativado
  pinMode(botaoPin, INPUT_PULLUP);

  digitalWrite(ledPin, LOW);

  Serial.begin(9600);
  Serial.println("Digite a senha:");
}

void loop() {

  // ==========================
  // Leitura do teclado
  // ==========================
  char tecla = teclado.getKey();

  if (tecla) {

    Serial.print("Tecla: ");
    Serial.println(tecla);

    // Tecla # confirma senha
    if (tecla == '#') {

      if (senhaDigitada == senhaCorreta) {
        sistemaLiberado = true;
        Serial.println("Senha correta! Sistema liberado.");
      } 
      else {
        sistemaLiberado = false;
        Serial.println("Senha incorreta!");
      }

      senhaDigitada = "";
    }

    // * limpa senha digitada
    else if (tecla == '*') {
      senhaDigitada = "";
      Serial.println("Senha apagada");
    }

    // Adiciona número digitado
    else {
      senhaDigitada += tecla;
    }
  }

  // ==========================
  // Controle do LED
  // ==========================
  if (sistemaLiberado) {

    // Botão pressionado = LOW
    if (digitalRead(botaoPin) == LOW) {
      digitalWrite(ledPin, HIGH);
    } 
    else {
      digitalWrite(ledPin, LOW);
    }
  } 
  else {
    digitalWrite(ledPin, LOW);
  }
}
