#include <Wire.h>
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

// Caractere personalizado: "ã"
byte a_til[8] = {
  B01010,
  B00101,
  B01110,
  B00001,
  B01111,
  B10001,
  B01111,
  B00000
};

void setup() {
  lcd.init();
  lcd.backlight();
  lcd.setCursor(4, 0);
  lcd.print("O Melhor");
  lcd.createChar(0, a_til); // posição 0

  lcd.setCursor(3, 1);
  lcd.print("Terceir");
  lcd.write(byte(0)); // imprime "ã"
  lcd.print("o");
}

void loop() {
}
